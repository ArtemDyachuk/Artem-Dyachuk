# Copy NEXT_PUBLIC_FIREBASE_* from resume-tailor/.env.local (same Firebase project)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: company logos from R2 (same values as resume-tailor/.env.local)
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Public logos (preferred). Same NEXT_PUBLIC_R2_PUBLIC_BASE_URL as resume-tailor.
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=

# HubSpot contact form
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_GUID=

# Local dev only — same domain saved in Resume Tailor /portfolio (customDomains lookup).
# Alternative: add "127.0.0.1 www.artemdyachuk.com" to /etc/hosts and skip this var.
PORTFOLIO_DEV_HOST=www.artemdyachuk.com
